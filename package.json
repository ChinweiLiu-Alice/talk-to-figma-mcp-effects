{
  "name": "talk-to-figma-mcp-effects",
  "description": "Fork of cursor-talk-to-figma-mcp with gradient fills, drop shadows, and layer blur support for AI-native UI design",
  "version": "0.4.0",
  "module": "dist/server.js",
  "main": "dist/server.js",
  "bin": {
    "talk-to-figma-mcp-effects": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "start": "bun run dist/server.js",
    "socket": "bun run src/socket.ts",
    "setup": "./scripts/setup.sh",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "bun run build:watch",
    "pub:release": "bun run build && npm publish"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.2.5",
    "tsup": "^8.4.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.13.1",
    "uuid": "latest",
    "ws": "latest",
    "zod": "3.22.4"
  }
}
